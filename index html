            setTimeout(() => {
                overlay.style.display = 'none';
                document.getElementById('mainAppContainer').style.display = 'block';
                checkAppUpdate();
                initCalendarSelects();
            }, 500);
        }, 2200);
    }

    function initPercentageSelector() {
        const pSel = document.getElementById("pctNum1");
        if(!pSel) return;
        const numbers = [48200, 57900, 67500, 77200, 86900, 96500, 106200, 115800, 125400, 135100, 144700, 154400, 164100, 173700, 183400, 193000, 202700, 212300, 222000, 231600, 241200, 250900, 260500, 270200, 279900, 289500, 299200, 308800, 318400, 328200, 337800, 347400, 357100, 366700, 376400, 386100];
        numbers.forEach(num => {
            let opt = document.createElement("option");
            opt.value = num; opt.textContent = num; pSel.appendChild(opt);
        });
    }

    document.getElementById('userPhoneNumber').addEventListener('keypress', function(e) { if (e.key === 'Enter') validateAccess(); });

    function checkAppUpdate() {
        if(!VERSION_CHECK_URL || VERSION_CHECK_URL.includes("your-username")) return;
        fetch(VERSION_CHECK_URL + "?v=" + new Date().getTime())
            .then(res => res.json())
            .then(data => { if (data.latestVersion !== CURRENT_VERSION) showUpdateModal(data.message, data.updateUrl); })
            .catch(err => console.log(err));
    }

    function showUpdateModal(message, updateUrl) {
        const modalHtml = `<div style="position:fixed; top:0; left:0; width:100%; height:100%; background:rgba(0,0,0,0.85); z-index:99999; display:flex; justify-content:center; align-items:center; padding:20px; box-sizing:border-box;"><div style="background:#fff; padding:25px; border-radius:12px; max-width:400px; width:100%; text-align:center;"><h3 style="color:#dc3545; margin-top:0;">ဗားရှင်းအသစ်ထွက်ရှိနေပါသည်</h3><p style="text-align:left;">${message}</p><a href="${updateUrl}" target="_blank" style="display:block; background:#28a745; color:#fff; padding:12px; border-radius:6px; font-weight:bold; text-decoration:none;">အပ်ဒိတ်လုပ်မည်</a></div></div>`;
        document.body.insertAdjacentHTML('beforeend', modalHtml);
    }

    // ==========================================
    // CASIO MJ-120D PLUS ENGINE
    // ==========================================
    let casioCurrentInput = "0"; let casioPreviousInput = ""; let casioActiveOp = null; let casioHistory = []; let casioHistoryIndex = -1; let casioIsResultShown = false; let casioGrandTotal = 0; let casioMemory = 0; let casioTaxRate = 5; 

    function casioRefreshScreen() {
        let displayStr = casioCurrentInput; if(displayStr.length > 12) displayStr = displayStr.substring(0, 12);
        document.getElementById("casio-display").textContent = displayStr;
        let stepCount = casioHistory.length > 0 ? casioHistory.length : 1; if (casioHistoryIndex !== -1) stepCount = casioHistoryIndex + 1;
        document.getElementById("casio-step-label").textContent = String(stepCount).padStart(3, '0');
        document.getElementById("casio-op-indicator").textContent = casioActiveOp ? casioActiveOp : "";
        document.getElementById("casio-gt-indicator").textContent = casioGrandTotal !== 0 ? "GT" : "";
    }

    function casioNum(num) {
        if(casioIsResultShown) { casioCurrentInput = "0"; casioIsResultShown = false; }
        if(num === "." && casioCurrentInput.includes(".")) return;
        casioCurrentInput = (casioCurrentInput === "0" && num !== ".") ? num : casioCurrentInput + num;
        casioRefreshScreen();
    }

    function casioOp(op) { casioActiveOp = op; casioPreviousInput = casioCurrentInput; casioIsResultShown = true; casioRefreshScreen(); }

    function casioEqual() {
        if (!casioActiveOp || !casioPreviousInput) return;
        let v1 = parseFloat(casioPreviousInput); let v2 = parseFloat(casioCurrentInput); let res = 0;
        switch(casioActiveOp) {
            case '➕': res = v1 + v2; break; case '➖': res = v1 - v2; break; case '✖': res = v1 * v2; break; case '➗': res = v2 !== 0 ? v1 / v2 : 0; break;
        }
        casioHistory.push({text: `${v1} ${casioActiveOp} ${v2} = ${res}`, val: res});
        casioHistoryIndex = casioHistory.length - 1; casioGrandTotal += res; casioCurrentInput = String(res); casioActiveOp = null; casioIsResultShown = true; casioRefreshScreen();
    }

    function casioCommand(cmd) {
        if (cmd === 'ac') { casioCurrentInput = "0"; casioPreviousInput = ""; casioActiveOp = null; casioHistory = []; casioHistoryIndex = -1; casioGrandTotal = 0; } 
        else if (cmd === 'c') { casioCurrentInput = "0"; } 
        else if (cmd === 'gt') { casioCurrentInput = String(casioGrandTotal); casioIsResultShown = true; } 
        else if (cmd === 'back' && casioHistoryIndex > 0) { casioHistoryIndex--; let r = casioHistory[casioHistoryIndex]; alert(`Step ${casioHistoryIndex + 1}: ${r.text}`); casioCurrentInput = String(r.val); } 
        else if (cmd === 'forward' && casioHistoryIndex < casioHistory.length - 1) { casioHistoryIndex++; let r = casioHistory[casioHistoryIndex]; alert(`Step ${casioHistoryIndex + 1}: ${r.text}`); casioCurrentInput = String(r.val); } 
        else if (cmd === 'autoreview') {
            if(casioHistory.length === 0) return; let idx = 0;
            let interval = setInterval(() => { if(idx < casioHistory.length) { casioCurrentInput = String(casioHistory[idx].val); casioHistoryIndex = idx; casioRefreshScreen(); idx++; } else clearInterval(interval); }, 1000);
        } else if (cmd === 'correct') {
            let newVal = prompt("တန်ဖိုးအသစ် ပြောင်းလဲသတ်မှတ်ပါ -", casioCurrentInput);
            if(newVal !== null && !isNaN(newVal)) { casioCurrentInput = newVal; if(casioHistoryIndex !== -1 && casioHistory[casioHistoryIndex]) casioHistory[casioHistoryIndex].val = parseFloat(newVal); }
        } else if (cmd === 'taxplus') { casioCurrentInput = String(parseFloat(casioCurrentInput) * (1 + casioTaxRate/100)); casioIsResultShown = true; } 
        else if (cmd === 'taxminus') { casioCurrentInput = String(parseFloat(casioCurrentInput) * (1 - casioTaxRate/100)); casioIsResultShown = true; } 
        else if (cmd === 'sqrt') { casioCurrentInput = String(Math.sqrt(parseFloat(casioCurrentInput))); casioIsResultShown = true; } 
        else if (cmd === 'percent') {
            if (casioActiveOp === '✖' && casioPreviousInput) {
                let res = (parseFloat(casioPreviousInput) / parseFloat(casioCurrentInput)) * 100;
                casioHistory.push({text: `${casioPreviousInput} ✖ ${casioCurrentInput}% = ${res}%`, val: res});
                casioHistoryIndex = casioHistory.length - 1; casioCurrentInput = String(res); casioActiveOp = null; casioIsResultShown = true;
            } else { casioCurrentInput = String(parseFloat(casioCurrentInput) / 100); casioIsResultShown = true; }
        } else if (cmd === 'mplus') { casioMemory += parseFloat(casioCurrentInput); casioIsResultShown = true; } 
        else if (cmd === 'mminus') { casioMemory -= parseFloat(casioCurrentInput); casioIsResultShown = true; } 
        else if (cmd === 'mrc') { casioCurrentInput = String(casioMemory); casioIsResultShown = true; }
        casioRefreshScreen();
    }

    // ==========================================
    // CALENDAR & AGE LOGIC
    // ==========================================
    function initCalendarSelects() {
        const yearSelect = document.getElementById('calYearSelect'); const monthSelect = document.getElementById('calMonthSelect'); const mmYearSelect = document.getElementById('calMmYearSelect');
        yearSelect.innerHTML = ""; mmYearSelect.innerHTML = ""; monthSelect.innerHTML = "";
        for (let y = 1930; y <= 2045; y++) { let opt = document.createElement('option'); opt.value = y; opt.textContent = y; yearSelect.appendChild(opt); }
        for (let my = 1292; my <= 2407; my++) { let opt = document.createElement('option'); opt.value = my; opt.textContent = my + " ခု"; mmYearSelect.appendChild(opt); }
        const enMonths = ["Jan", "Feb", "Mar", "Apr", "May", "Jun", "Jul", "Aug", "Sep", "Oct", "Nov", "Dec"];
        enMonths.forEach((m, idx) => { let opt = document.createElement('option'); opt.value = idx; opt.textContent = m; monthSelect.appendChild(opt); });
        const today = new Date(); currentCalYear = today.getFullYear(); currentCalMonth = today.getMonth();
        yearSelect.value = currentCalYear; monthSelect.value = currentCalMonth;
    }

    function toggleCalendar(show) { document.getElementById('calendarModal').style.display = show ? 'flex' : 'none'; if (show) { toggleMmYearSelector(false); updateCalendarView(); } }
    function toggleMmYearSelector(show) {
        const textEl = document.getElementById('calMmTitleText'); const selectWrap = document.getElementById('mmYearSelectorWrap');
        if (show) { textEl.style.display = 'none'; selectWrap.style.display = 'flex'; let currentMmYear = currentCalYear - 638; if (currentCalMonth < 3) currentMmYear--; document.getElementById('calMmYearSelect').value = currentMmYear; } 
        else { textEl.style.display = 'inline-block'; selectWrap.style.display = 'none'; }
    }

    function handleMmYearChange() {
        currentCalYear = parseInt(document.getElementById('calMmYearSelect').value) + 638; if (currentCalMonth < 3) currentCalYear++;
        document.getElementById('calYearSelect').value = currentCalYear; toggleMmYearSelector(false); updateCalendarView();
    }

    function changeMonth(direction) {
        currentCalMonth += direction; if (currentCalMonth > 11) { currentCalMonth = 0; currentCalYear++; } else if (currentCalMonth < 0) { currentCalMonth = 11; currentCalYear--; }
        document.getElementById('calYearSelect').value = currentCalYear; document.getElementById('calMonthSelect').value = currentCalMonth; toggleMmYearSelector(false); updateCalendarView();
    }

    function updateCalendarView() {
        currentCalYear = parseInt(document.getElementById('calYearSelect').value); currentCalMonth = parseInt(document.getElementById('calMonthSelect').value);
        const grid = document.getElementById('calendarDaysGrid'); grid.innerHTML = '';
        document.getElementById('calEngTitleText').textContent = `${engMonthsFull[currentCalMonth]} ${currentCalYear}`;
        let estMy = currentCalYear - 638; if (currentCalMonth < 3) estMy--;
        document.getElementById('calMmTitleText').textContent = `${estMy} ခု ${mmMonthsList[currentCalMonth]} - ${mmMonthsList[(currentCalMonth + 1) % 12]}`;
        const firstDayIndex = new Date(currentCalYear, currentCalMonth, 1).getDay(); const totalDays = new Date(currentCalYear, currentCalMonth + 1, 0).getDate(); const todayDate = new Date();
        for (let i = 0; i < firstDayIndex; i++) { let emptyCell = document.createElement('div'); emptyCell.className = 'day-cell empty'; grid.appendChild(emptyCell); }
        for (let day = 1; day <= totalDays; day++) {
            let cell = document.createElement('div'); cell.className = 'day-cell';
            let cwd = new Date(currentCalYear, currentCalMonth, day).getDay();
            if (cwd === 0) cell.classList.add('is-sun'); if (cwd === 6) cell.classList.add('is-sat');
            if (currentCalYear === todayDate.getFullYear() && currentCalMonth === todayDate.getMonth() && day === todayDate.getDate()) cell.classList.add('today');
            let mmDayNum = day % 15 === 0 ? 15 : day % 15;
            let phaseClass = "", phaseText = "";
            if (day === 15) { phaseText = "လပြည့်"; phaseClass = "moon-full"; } 
            else if (day === totalDays) { phaseText = "လကွယ်"; phaseClass = "moon-dark"; } 
            else if (day < 15) { phaseText = `လဆန်း ${mmDayNum}`; phaseClass = "moon-up"; } 
            else { phaseText = `လဆုတ် ${mmDayNum}`; phaseClass = "moon-down"; }
            cell.innerHTML = `<div class="eng-num">${day}</div><div class="mm-num ${phaseClass}">${phaseText}</div>`;
            cell.onclick = () => { toggleCalendar(false); document.getElementById('enYear').value = currentCalYear; document.getElementById('enMonth').value = currentCalMonth + 1; document.getElementById('enDay').value = day; calculateEnglishAge(); };
            grid.appendChild(cell);
        }
    }

    function showSmartPopup(years, months, days, infoText) {
        const modal = document.getElementById('ageModal'); const titleEl = document.getElementById('modalTitle'); const textEl = document.getElementById('modalText'); const buttonsEl = document.getElementById('modalButtons'); const boxEl = document.querySelector('.modal-box p');
        const selectedType = document.querySelector('input[name="appType"]:checked').value;
        let maxAgeLimit = (selectedType === 'old') ? 70 : 62; 
        let typeLabel = (selectedType === 'old') ? "သတ်မှတ်ချက် (၁၈ - ၇၀) နှစ်" : "သတ်မှတ်ချက် (၁၈ - ၆၂) နှစ်";
        let ageResultHtml = `<b>အသက်တွက်ချက်မှုရလဒ် [${typeLabel}] -</b><br>` + infoText + `<br>` + `• လက်ရှိအသက် - <b>${years} နှစ်၊ ${months} လ၊ ${days} ရက်</b>`;
        let isOverAge = years > maxAgeLimit || (years === maxAgeLimit && (months > 0 || days > 0));

        if (years >= 18 && !isOverAge) {
            titleEl.className = "status-pass"; titleEl.innerHTML = "အောင်မြင်ပါသည်"; boxEl.style.borderLeftColor = "#28a745";
            textEl.innerHTML = ageResultHtml + `<hr style="border:0; border-top:1px dashed #ddd; margin:12px 0;"><span style="color:#1e3a8a; font-weight:bold;">MCIX သို့ သွားမည်လား (Password အလိုအလျောက် Copy ကူးပေးမည်)</span>`;
            buttonsEl.innerHTML = `<button class="modal-btn btn-yes" onclick="handlePopupChoice(true)">Yes (သွားမည်)</button><button class="modal-btn btn-no" onclick="handlePopupChoice(false)">No (မသွားပါ)</button>`;
        } else {
            titleEl.className = "status-fail"; boxEl.style.borderLeftColor = "#dc3545";
            titleEl.innerHTML = isOverAge ? `အသက်ကျော်လွန်နေပါသည် (အသက် ${maxAgeLimit} နှစ်ထက်ကျော်နေပါသည်)` : "အသက်မပြည့်သေးပါ (အသက် ၁၈ နှစ်အောက်ဖြစ်နေပါသည်)";
            textEl.innerHTML = ageResultHtml + `<hr style="border:0; border-top:1px dashed #ddd; margin:12px 0;"><span style="color:#dc3545; font-weight:bold;">စည်းကမ်းချက်နှင့် မကိုက်ညီပါ (အသက် ၁၈ မှ ${maxAgeLimit} အတွင်းသာ ဖြစ်ရပါမည်)</span>`;
            buttonsEl.innerHTML = `<button class="modal-btn btn-ok" onclick="handlePopupChoice(false)">OK (သိပါပြီ)</button>`;
        }
        modal.style.display = 'flex';
    }

    function handlePopupChoice(goToMcix) { document.getElementById('ageModal').style.display = 'none'; if (goToMcix) triggerMCIX(); }
    function switchTab(tabId, btn, isMm) {
        document.querySelectorAll('.calculator-form').forEach(form => form.classList.remove('active')); document.querySelectorAll('.tab-btn').forEach(tBtn => tBtn.classList.remove('active', 'mm-active'));
        document.getElementById(tabId).classList.add('active'); btn.classList.add('active'); if(isMm) btn.classList.add('mm-active');
    }

    function calculateEnglishAge() {
        const year = parseInt(document.getElementById('enYear').value); const month = parseInt(document.getElementById('enMonth').value); const day = parseInt(document.getElementById('enDay').value);
        if (!year || !day || isNaN(month)) { alert("ကျေးဇူးပြု၍ မွေးသက္ကရာဇ် အပြည့်အစုံ ဖြည့်စွက်ပေးပါဗျာ။"); return; }
        const dob = new Date(year, month - 1, day); const today = new Date(); if (dob > today) { alert("မွေးသက္ကရာဇ်သည် ယနေ့ထက် ကြီးနေ၍ မရပါဗျာ။"); return; }
        let years = today.getFullYear() - dob.getFullYear(); let months = today.getMonth() - dob.getMonth(); let days = today.getDate() - dob.getDate();
        if (days < 0) { months--; days += new Date(today.getFullYear(), today.getMonth(), 0).getDate(); } if (months < 0) { years--; months += 12; }
        showSmartPopup(years, months, days, `• မွေးသက္ကရာဇ် - <b>${year} ခုနှစ်၊ ${document.getElementById('enMonth').options[month-1].text}၊ ${day} ရက်</b>`);
    }

    function calculateMyanmarAge() {
        const birthYear = parseInt(document.getElementById('mmYear').value); const birthMonth = parseInt(document.getElementById('mmMonth').value); const birthPhase = parseInt(document.getElementById('moonPhase').value); const birthDay = parseInt(document.getElementById('mmDay').value);
        if (!birthYear || !birthDay) { alert("ကျေးဇူးပြု၍ မွေးသက္ကရာဇ် အပြည့်အစုံ ဖြည့်စွက်ပေးပါဗျာ။"); return; }
        const current = { year: 1388, month: 6, phase: (new Date().getDate() > 15) ? 2 : 1, day: new Date().getDate() % 15 === 0 ? 15 : new Date().getDate() % 15 };
        if (birthYear > current.year) { alert("မွေးသက္ကရာဇ်သည် ယနေ့ထက် ကြီးနေ၍ မရပါဗျာ။"); return; }
        let years = current.year - birthYear; let months = current.month - birthMonth; let days = current.day - birthDay;
        if (days < 0) { months--; days += 15; } if (months < 0) { years--; months += 12; } if (birthYear === 1326 && years < 62) years = 62;
        showSmartPopup(years, months, days, `• မွေးသက္ကရာဇ် - <b>မြန်မာသက္ကရာဇ် ${birthYear} ခု၊ ${document.getElementById('mmMonth').options[birthMonth-1].text} ${(birthPhase === 1 ? 'လဆန်း' : 'လဆုတ်')} ${birthDay} ရက်</b>`);
    }
