    // New Streamlined Lifecycle Check
    window.onload = function() {
        const currentDeviceId = getDeviceID();
        initPercentageSelector();
        
        // Configuration elements
        const spinner = document.getElementById('loginSpinner');
        const activationBox = document.getElementById('activationInputBox');
        const infoPara = document.getElementById('lockInfoText');
        
        if (infoPara) {
            infoPara.innerHTML = `<b>Device ID: <span style="color:#28a745;">${currentDeviceId}</span></b><br>` +
                                 `<span style="color:#666; font-size:12px;">(ဤ Device ID အတွက် Approved Key တောင်းယူပါ)</span>`;
        }

        // SCENARIO 1: Alreading validated device -> Trigger directly Matrix Transition
        if (localStorage.getItem("ksl_device_activated") === "true" && localStorage.getItem("ksl_used_key")) {
            spinner.style.display = 'block';
            activationBox.style.display = 'none'; // Keep box away from UI entirely
            
            setTimeout(() => {
                runMatrixWelcomeAnimation();
            }, 1000);
        } 
        // SCENARIO 2: Brand new or unauthenticated device -> Request Activation Key Box
        else {
            spinner.style.display = 'none';
            activationBox.style.display = 'block';
        }
    };

    function validateAccess() {
        const inputKey = document.getElementById('userPhoneNumber').value.trim();
        const currentDeviceId = getDeviceID();
        if (!inputKey) { alert("ကျေးဇူးပြု၍ Activation Key ရိုက်ထည့်ပေးပါဗျာ။"); return; }

        // Transition elements during processing
        document.getElementById('activationInputBox').style.display = 'none';
        document.getElementById('loginSpinner').style.display = 'block';

        fetch(`${WEB_APP_URL}?key=${encodeURIComponent(inputKey)}&deviceId=${encodeURIComponent(currentDeviceId)}&action=check`)
        .then(res => res.json())
        .then(response => {
            if (response.status === "invalid" || response.status === "used") {
                alert(response.status === "invalid" ? "❌ ဤ Key သည် Register မလုပ်ရသေးပါ။" : "❌ ဤ Key သည် အခြားဖုန်းတစ်ခုတွင် အသုံးပြုပြီးဖြစ်သည်။");
                document.getElementById('loginSpinner').style.display = 'none';
                document.getElementById('activationInputBox').style.display = 'block';
            } else if (response.status === "activated" || response.status === "matched") {
                localStorage.setItem("ksl_used_key", inputKey);
                localStorage.setItem("ksl_device_activated", "true");
                runMatrixWelcomeAnimation();
            }
        })
        .catch(() => {
            alert("အင်တာနက်လိုင်း မကောင်းပါ သို့မဟုတ် Apps Script URL မှားယွင်းနေပါသည်ဗျာ။");
            document.getElementById('loginSpinner').style.display = 'none';
            document.getElementById('activationInputBox').style.display = 'block';
        });
    }

    // Matrix Sequence Handler
    function runMatrixWelcomeAnimation() {
        document.getElementById('loginSpinner').style.display = 'none';
        document.getElementById('activationInputBox').style.display = 'none';
        
        const matrixSection = document.getElementById('matrixWelcome');
        matrixSection.style.display = 'flex';
        
        // Keep the Matrix terminal interface briefly for styling effect before entering app
        setTimeout(() => {
            const overlay = document.getElementById('loginOverlay');
