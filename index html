        if (isNaN(n1) || isNaN(n2)) { alert("ကျေးဇူးပြု၍ ကိန်းဂဏန်းနှစ်ခုလုံးကို မှန်ကန်စွာ ရိုက်ထည့်ပေးပါဗျာ။"); return; }
        if (n2 === 0) { alert("ဒုတိယကိန်းဂဏန်းသည် သုည (0) မဖြစ်ရပါဗျာ။"); return; }
        let percentage = Math.round(((n1 / n2) * 100) * 10000) / 10000;
        let resultBox = document.getElementById("pctResultBox");
