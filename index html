    function getDeviceID() {
        let deviceId = localStorage.getItem("ksl_device_id");
        if (!deviceId) {
            deviceId = "KSL-" + Math.floor(1000 + Math.random() * 9000);
            localStorage.setItem("ksl_device_id", deviceId);
